#ifndef BEE_FISH__POWER_ENCODING__STACK_HPP
#define BEE_FISH__POWER_ENCODING__STACK_HPP

#include <bitset>

namespace BeeFishPowerEncoding
{
using namespace std;
using namespace BeeFishPowerEncoding;

class Stack :
    public PowerEncoding,
    public vector<bool>
{
private:
    size_t _index = 0;

public:
    Stack()
    {
        _index = 0;
    }

    Stack(const Stack& stack) :
        vector<bool>(stack)
    {
        _index = 0;
    }

    Stack(const std::string& data)
    {
        // [0,1,2,3,4,5,6,7]
        const unsigned char* _data = (const unsigned char*)data.data();
        const size_t _size = data.size();

        reserve(_size * 8);

        ssize_t count = 0;

        for (size_t byteIndex = 0; byteIndex < _size; ++byteIndex) {

            unsigned char byte = _data[byteIndex];

            bitset<8> bits = byte;

            for ( size_t bitIndex = 0;
                    bitIndex < 8;
                    ++bitIndex )
            {
                bool bit = bits[7 - bitIndex];

                if (count >= 0) {

                    if (bit)
                        ++count;
                    else
                        --count;

                    if (count >= 0)
                        push_back(bit);

                }

            }
        }

        _index = 0;

    }

    virtual ~Stack() {
    }

    virtual bool peekBit() const
    {
        if (_index == 0)
            return 0;
            
        return (*this)[_index];
    }

    virtual bool readBit()
    override
    {

        bool value = peekBit();

        PowerEncoding::readBit();

        if (_index < size())
            ++_index;

        return value;
    }

    virtual void writeBit(bool bit)
    override
    {
        PowerEncoding::writeBit(bit);
        push_back(bit);
    }

    virtual void reset()
    {
        _index = 0;
        PowerEncoding::reset();
    }

    virtual void clear()
    {
        reset();
        vector<bool>::clear();
    }

    long int count() const
    {
        return _count;
    }

    bool last() const {
        size_t size = vector<bool>::size();
        assert(size);
        return (*this)[size - 1];
    }

    std::string toData() const
    {
        std::vector<unsigned char> bytes;
        int count = 0;
        int bitCount = 0;
        bitset<8> bits = 0;

        for (bool bit : *this)
        {

            bits[7 - bitCount] = bit;
            if (++bitCount == 8)
            {
                unsigned char byte =
                    bits.to_ulong();
                bytes.push_back(byte);
                bits = 0;
                bitCount = 0;
            }
            if (bit)
                ++count;
            else
                --count;
        }

        if (bitCount > 0)
        {
            unsigned char byte =
                bits.to_ulong();
            bytes.push_back(byte);
        }

        std::string copy((const char*)bytes.data(), bytes.size());

        return copy;
    }

    static Stack fromData(const std::string& data)
    {
        return Stack(data);
    }

    std::string str() {
        std::string string;
        for (auto bit : (*this)) {
            string.push_back(bit ? '1' : '0');
        }
        return string;
    }


    virtual void push_back(bool bit)
    {

        if (bit)
            ++_count;
        else if (_count > 0)
            --_count;

        vector<bool>::push_back(
            bit
        );

    }


    virtual void pop_back()
    {
        bool bit = last();

        if (bit && _count > 0)
            --_count;
        else if (!bit)
            ++_count;

        vector<bool>::pop_back();

    }

    friend ostream& operator << (
        ostream& output,
        const Stack& stack
    )
    {
        for (auto const bit : stack)
        {
            output << bit;
        }

        output << endl;

        return output;
    }

    friend PowerEncoding& operator << (PowerEncoding& stream, const Stack& stack)
    {
        for (const auto bit : stack)
            stream.writeBit(bit);

        return stream;
    }

    friend PowerEncoding& operator >> (PowerEncoding& stream, Stack& stack)
    {
        size_t count = 0;

        do
        {
            bool bit = stream.readBit();
            if (bit)
                ++count;
            else
                --count;
            stack.push_back(bit);
        }
        while (count > 0);

        assert(stack.count() == 0);

        return stream;
    }



};




}

#endif
