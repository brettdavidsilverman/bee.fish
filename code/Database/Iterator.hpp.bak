#ifndef BEE_FISH__DATABASE__ITERATOR_HPP
#define BEE_FISH__DATABASE__ITERATOR_HPP

#include "Iterable.hpp"

namespace BeeFishDatabase {

template<typename T>
class Iterator {
public:
    Iterable<T>* _iterable = nullptr; // The underlying pointer that the iterator wraps
    T _item;
    Stack _stack;
    bool _isEnd = true;

public:
    // Iterator traits (required for STL compatibility in C++17 and earlier)
    using iterator_category = std::forward_iterator_tag;
    using value_type        = T;
    using difference_type   = std::ptrdiff_t;
    using pointer           = T*;
    using reference         = const T&;

    // Constructor
    Iterator() {
    }


    Iterator(const Iterable* iterable) :
        _iterable(iterable->copy())
    {
        _isEnd = !_iterable->next<T>(_stack, _item);

    }
    
    Iterator(const Iterable* iterable, const Stack& stack) :
        _iterable(iterable->copy()),
        _stack(stack)
    {
        _isEnd = !_iterable->next<T>(_stack, _item);

    }
    
    Iterator(const Iterator& source) :
        _iterable(source._iterable->copy()),
        _item(source._item),
        _stack(source._stack),
        _isEnd(source._isEnd)
    {
    }
    
    virtual ~Iterator()
    {
        if (_iterable)
            delete _iterable;
    }


    // Dereference operator (*)
    reference operator*() const
    {
        return _item;
    }

    // Arrow operator (->)
    pointer operator->()
    {
        return &_item;
    }

    // Prefix increment operator (++)
    Iterator& operator++() {
        assert(!_isEnd);
        _isEnd = not
                 _iterable->next<T>(
                     _stack,
                     _item
                 );
        return *this;
    }

    // Postfix increment operator (++)
    Iterator operator++(int) {
        Iterator tmp = *this;
        tmp.save();
        ++(*this);
        tmp.restore();
        return tmp;
    }
    
    /*

    void save()
    {
        _iterable->save();
    }

    void restore()
    {
        _iterable->restore();
    }
*/
    friend bool operator == (
        const Iterator& a,
        const Iterator& b
    )
    {
        return  (a._isEnd == b._isEnd);
    }

    friend bool operator != (
        const Iterator& a,
        const Iterator& b
    )
    {
        return (a._isEnd != b._isEnd);
    }


};
}

#endif