#ifndef BEE_FISH_JSON__NUMBER_H
#define BEE_FISH_JSON__NUMBER_H

#include "../parser/parser.h"

using namespace bee::fish::parser;

namespace bee::fish::json {
      
   class NumberPtr :
      public MatchPtr
   {
   public:
      NumberPtr() : MatchPtr(
         OPTIONAL(
            SignPtr(),
            IntegerPtr()
         ) and
         OPTIONAL(
            FractionPtr(),
            _OPTIONAL(
               ExponentPtr()
            )
         )
      )
      {
      }
      
      class IntegerCharacter : public Range
      {
      public:
         IntegerCharacter() : Range('0', '9')
         {
         }
            
      };
      
      class IntegerPtr : public MatchPtr
      {
      public:
         IntegerPtr() : MatchPtr(
            new Repeat(
               MatchPtr(
                  new IntegerCharacter()
               ),
               NOT(
                  MatchPtr(
                     new IntegerCharacter()
                  )
               ),
               1,
               0
            )
         )
         {
         }

      };
      
      class FractionPtr : public MatchPtr
      {
      public:
         FractionPtr() : MatchPtr(
            CHARACTER('.') and
            IntegerPtr()
         )
         {
         }
      };
      
      class ExponentPtr : public MatchPtr
      {
      public:
         ExponentPtr() : MatchPtr(
            (
               CHARACTER('E') or
               CHARACTER('e')
            ) and
            OPTIONAL(
               SignPtr(),
               IntegerPtr()
            )
         )
         {
         }
      };
      
      class SignPtr : public MatchPtr
      {
      public:
         SignPtr() : MatchPtr(
            CHARACTER('+') or
            CHARACTER('-')
         )
         {
         }
      };
      
      virtual void write(ostream& out)
      {
         out << "Number";
         (*this)->writeResult(out);
         out << "()";
      }
         
   };
}

#endif